                S = np.cos(np.pi * u_norm) * np.cos(np.pi * v_norm)

                # --- LINE 332 --- 

                threshold = (S + 1.0) / 2.0

            # --- LINE 333 --- 

            else:  # diamond

                # --- LINE 334 --- 

                S = np.cos(np.pi * u_norm) + np.cos(np.pi * (u_norm + v_norm)/2.0)

                # --- LINE 335 --- 

                threshold = (S + 2.0) / 4.0

# --- LINE 336 --- 



            # --- LINE 337 --- 

            ink_density = (255.0 - channel_array[y, x]) / 255.0

            # --- LINE 338 --- 

            result[y, x] = 0 if ink_density > threshold else 255

# --- LINE 339 --- 



