@jit(nopython=True, parallel=True, cache=True)

# --- LINE 303 --- 

def apply_halftone_fast(channel_array, lpi, dpi, angle_deg, shape_type):

    # --- LINE 304 --- 

    """Semitono optimizado con Numba - 10x mÃ¡s rÃ¡pido"""

    # --- LINE 305 --- 
    #   $6load_attr.1 = getattr(value=channel_array, attr=shape)  :: UniTuple(int64 x 2)
    #   $26unpack_sequence.4 = exhaust_iter(value=$6load_attr.1, count=2)  :: UniTuple(int64 x 2)
    #   del $6load_attr.1
    #   $h.37 = static_getitem(value=$26unpack_sequence.4, index=0, index_var=None, fn=<built-in function getitem>)  :: int64
    #   $w.36 = static_getitem(value=$26unpack_sequence.4, index=1, index_var=None, fn=<built-in function getitem>)  :: int64
    #   del $26unpack_sequence.4

    h, w = channel_array.shape

    # --- LINE 306 --- 
    #   $32load_global.5 = global(np: <module 'numpy' from 'C:\\Users\\elmer\\AppData\\Roaming\\Python\\Python314\\site-packages\\numpy\\__init__.py'>)  :: Module(<module 'numpy' from 'C:\\Users\\elmer\\AppData\\Roaming\\Python\\Python314\\site-packages\\numpy\\__init__.py'>)
    #   $42load_attr.6 = getattr(value=$32load_global.5, attr=deg2rad)  :: Function(<ufunc 'deg2rad'>)
    #   del $32load_global.5
    #   theta = call $42load_attr.6(angle_deg, func=$42load_attr.6, args=[Var(angle_deg, app.py:302)], kws=(), vararg=None, varkwarg=None, target=None)  :: (int64,) -> float64
    #   del angle_deg
    #   del $42load_attr.6

    theta = np.deg2rad(angle_deg)

    # --- LINE 307 --- 
    #   T = dpi / lpi  :: float64
    #   del lpi
    #   del dpi

    T = dpi / lpi

# --- LINE 308 --- 



    # --- LINE 309 --- 
    #   id=0[LoopNest(index_variable = parfor_index.20, range = (0, channel_array_size0.1, 1)), LoopNest(index_variable = parfor_index.21, range = (0, channel_array_size1.2, 1))]{1773: <ir.Block at C:\Users\elmer\Downloads\halftone_rip_pro_v2(18)\halftone_rip_pro_v2\app.py (309)>}Var($parfor_index_tuple_var.27, app.py:309)

    result = np.zeros((h, w), dtype=np.uint8)

    # --- LINE 310 --- 
    #   $170load_global.23 = global(np: <module 'numpy' from 'C:\\Users\\elmer\\AppData\\Roaming\\Python\\Python314\\site-packages\\numpy\\__init__.py'>)  :: Module(<module 'numpy' from 'C:\\Users\\elmer\\AppData\\Roaming\\Python\\Python314\\site-packages\\numpy\\__init__.py'>)
    #   $180load_attr.24 = getattr(value=$170load_global.23, attr=cos)  :: Function(<ufunc 'cos'>)
    #   del $170load_global.23
    #   cos_t = call $180load_attr.24(theta, func=$180load_attr.24, args=[Var(theta, app.py:306)], kws=(), vararg=None, varkwarg=None, target=None)  :: (float64,) -> float64
    #   del $180load_attr.24

    cos_t = np.cos(theta)

    # --- LINE 311 --- 
    #   $214load_global.28 = global(np: <module 'numpy' from 'C:\\Users\\elmer\\AppData\\Roaming\\Python\\Python314\\site-packages\\numpy\\__init__.py'>)  :: Module(<module 'numpy' from 'C:\\Users\\elmer\\AppData\\Roaming\\Python\\Python314\\site-packages\\numpy\\__init__.py'>)
    #   $224load_attr.29 = getattr(value=$214load_global.28, attr=sin)  :: Function(<ufunc 'sin'>)
    #   del $214load_global.28
    #   sin_t = call $224load_attr.29(theta, func=$224load_attr.29, args=[Var(theta, app.py:306)], kws=(), vararg=None, varkwarg=None, target=None)  :: (float64,) -> float64
    #   del theta
    #   del $224load_attr.29

    sin_t = np.sin(theta)

# --- LINE 312 --- 



    # --- LINE 313 --- 
    #   id=2[LoopNest(index_variable = parfor_index.30, range = (0, $h.37, 1))]{286: <ir.Block at C:\Users\elmer\Downloads\halftone_rip_pro_v2(18)\halftone_rip_pro_v2\app.py (313)>}Var(parfor_index.30, app.py:313)
    #   del v_norm
    #   del u_norm
    #   del threshold.5
    #   del sin_t
    #   del shape_type
    #   del parfor_index.28
    #   del cos_t
    #   del channel_array
    #   del T
    #   del $w.36
    #   del $phi1746.2.2

    for y in prange(h):

        # --- LINE 314 --- 

        for x in prange(w):

            # --- LINE 315 --- 

            u = x * cos_t - y * sin_t

            # --- LINE 316 --- 

            v = x * sin_t + y * cos_t

# --- LINE 317 --- 



            # --- LINE 318 --- 

            u_norm = ((u / T) - np.round(u / T)) * 2.0

            # --- LINE 319 --- 

            v_norm = ((v / T) - np.round(v / T)) * 2.0

# --- LINE 320 --- 



            # --- LINE 321 --- 

            if shape_type == 0:  # round

                # --- LINE 322 --- 

                S = np.cos(np.pi * u_norm) + np.cos(np.pi * v_norm)

                # --- LINE 323 --- 

                threshold = (S + 2.0) / 4.0

            # --- LINE 324 --- 

            elif shape_type == 1:  # ellipse

                # --- LINE 325 --- 

                S = 3.0 * np.cos(np.pi * u_norm) + np.cos(np.pi * v_norm)

                # --- LINE 326 --- 

                threshold = (S + 4.0) / 8.0

            # --- LINE 327 --- 

            elif shape_type == 2:  # line

                # --- LINE 328 --- 

                S = np.cos(np.pi * v_norm)

                # --- LINE 329 --- 

                threshold = (S + 1.0) / 2.0

            # --- LINE 330 --- 

            elif shape_type == 3:  # square

